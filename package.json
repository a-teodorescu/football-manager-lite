{
  "name": "football-manager-lite",
  "version": "0.6.0",
  "private": true,
  "description": "A browser/mobile football management simulator prototype with Supabase Auth, per-user saves, club creation, squad, tactics, season simulation, and standings.",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "simulate": "tsx src/engine/testSimulation.ts",
    "batch": "tsx src/engine/simulationBatchTest.ts",
    "check": "tsc --noEmit",
    "season": "tsx src/engine/testSeason.ts"
  },
  "dependencies": {
    "@vitejs/plugin-react": "4.3.4",
    "vite": "5.4.14",
    "typescript": "5.7.2",
    "tsx": "4.19.2",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "@types/node": "20.17.10",
    "@types/react": "18.3.18",
    "@types/react-dom": "18.3.5"
  },
  "packageManager": "npm@10.8.2"
}

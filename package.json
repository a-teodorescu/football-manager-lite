{
  "name": "football-manager-lite",
  "version": "0.2.0",
  "private": true,
  "description": "A browser/mobile football management simulator prototype with a deterministic TypeScript match engine and Vite React UI.",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "simulate": "tsx src/engine/testSimulation.ts",
    "batch": "tsx src/engine/simulationBatchTest.ts",
    "check": "tsc --noEmit"
  },
  "dependencies": {
    "@vitejs/plugin-react": "latest",
    "vite": "latest",
    "typescript": "latest",
    "tsx": "latest",
    "react": "latest",
    "react-dom": "latest",
    "@types/node": "latest",
    "@types/react": "latest",
    "@types/react-dom": "latest"
  }
}
